# Optional — Groq API key (FREE tier). Get one at https://console.groq.com/keys
# If unset, the "Ask UGAT" agent automatically uses scripted reasoning (still fully works, zero cost).
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional — override the Groq model. Defaults to llama-3.3-70b-versatile (free).
GROQ_MODEL=llama-3.3-70b-versatile
